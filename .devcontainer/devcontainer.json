{
  "name": "ERP-SMS Frappe Development Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "development",
  "workspaceFolder": "/home/frappe/frappe-bench/apps/sms_aftersales",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.formatting.provider": "black"
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [8000, 3306, 13000, 11000],
  "postCreateCommand": "echo 'ERP-SMS Dev Container Ready! Run: bench --site sms-dev.local migrate'",
  "remoteUser": "frappe"
}
